{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://rsfieaipypagioylevbp.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "netszukacz-mcp",
      "version": "0.3.0",
      "title": "netszukacz.pl MCP"
    },
    "tools": [
      {
        "name": "search_offers",
        "title": "Wyszukaj oferty",
        "description": "Szuka najlepszych ofert produktowych z wynagrodzeniem (cashback) u partnerów zintegrowanych z netszukacz.pl. Zwraca listę ujednoliconą i posortowaną po cenie efektywnej.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 2,
              "maxLength": 100,
              "description": "Fraza wyszukiwania, np. 'iPhone 15'."
            },
            "limit": {
              "description": "Maksymalna liczba wyników (domyślnie 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "sort": {
              "description": "Kolejność sortowania. Domyślnie 'price_effective' (najniższa cena po cashbacku).",
              "type": "string",
              "enum": [
                "price_effective",
                "price",
                "cashback",
                "rating"
              ]
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_rewards",
        "title": "Lista nagród",
        "description": "Zwraca aktywne nagrody dostępne do wymiany za punkty. Obsługuje wyszukiwanie tekstowe, filtr dostępności, zakres kosztu w punktach, sortowanie i stronicowanie (limit + offset).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "search": {
              "description": "Fraza filtrująca po nazwie nagrody (ILIKE).",
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "in_stock_only": {
              "description": "Jeśli true – zwraca wyłącznie nagrody z dostępnym stanem magazynowym (stock > 0 lub NULL = nielimitowane).",
              "type": "boolean"
            },
            "min_points": {
              "description": "Minimalny koszt w punktach.",
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "max_points": {
              "description": "Maksymalny koszt w punktach.",
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "sort": {
              "description": "Kolejność sortowania (domyślnie 'points_asc').",
              "type": "string",
              "enum": [
                "points_asc",
                "points_desc",
                "newest"
              ]
            },
            "limit": {
              "description": "Rozmiar strony (domyślnie 25, max 100).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "offset": {
              "description": "Przesunięcie strony (domyślnie 0).",
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "reward_details",
        "title": "Szczegóły nagrody",
        "description": "Zwraca szczegóły pojedynczej nagrody po `reward_id`: opis, koszt w punktach, dostępność (stock, is_active), globalne ustawienia programu lojalnościowego oraz — jeśli użytkownik jest zalogowany — jego saldo punktów i informację, czy stać go na wymianę. Zwraca czytelny błąd, gdy nagroda nie istnieje lub jest nieaktywna.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "reward_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "UUID nagrody w tabeli `rewards`."
            }
          },
          "required": [
            "reward_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "my_points",
        "title": "Moje punkty",
        "description": "Zwraca saldo punktów zalogowanego użytkownika (balance), sumę zdobytych punktów (total_earned), aktualną serię dni aktywności oraz kilka ostatnich transakcji punktowych.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "my_favorites",
        "title": "Moje ulubione oferty",
        "description": "Zwraca listę produktów dodanych do ulubionych przez zalogowanego użytkownika, z sortowaniem po dacie dodania oraz stronicowaniem.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Rozmiar strony (domyślnie 25).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "offset": {
              "description": "Przesunięcie strony (domyślnie 0).",
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "sort": {
              "description": "Kolejność (domyślnie 'newest').",
              "type": "string",
              "enum": [
                "newest",
                "oldest"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "add_favorite",
        "title": "Dodaj do ulubionych",
        "description": "Dodaje ofertę (product_name) do ulubionych zalogowanego użytkownika. Zwraca status ('added' lub 'already_exists') oraz aktualną listę ulubionych po operacji.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "product_name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500,
              "description": "Identyfikator/nazwa produktu, który ma zostać zapisany w ulubionych."
            }
          },
          "required": [
            "product_name"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "remove_favorite",
        "title": "Usuń z ulubionych",
        "description": "Usuwa ofertę z ulubionych zalogowanego użytkownika po `favorite_id` lub `product_name`. Zwraca status ('removed' lub 'not_found') oraz aktualną listę ulubionych po operacji.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "favorite_id": {
              "description": "UUID rekordu w tabeli favorites.",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "product_name": {
              "description": "Alternatywnie: identyfikator/nazwa produktu do usunięcia.",
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "my_redemptions",
        "title": "Moja historia wymian nagród",
        "description": "Zwraca historię wymian nagród zalogowanego użytkownika (koszt punktowy, status, data). Wspiera stronicowanie i filtr statusu.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "description": "Opcjonalny filtr statusu wymiany.",
              "type": "string",
              "enum": [
                "pending",
                "processing",
                "shipped",
                "completed",
                "cancelled"
              ]
            },
            "limit": {
              "description": "Rozmiar strony (domyślnie 25).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "offset": {
              "description": "Przesunięcie strony (domyślnie 0).",
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
