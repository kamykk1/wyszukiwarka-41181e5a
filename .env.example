########################################
# netszukacz.pl — self-hosted (.env)
########################################

# --- PostgreSQL ---
POSTGRES_PASSWORD=zmien-na-silne-haslo-min-20-znakow

# --- JWT (podpisuje anon + service_role) ---
# Wygeneruj: openssl rand -base64 48
JWT_SECRET=zmien-na-losowy-ciag-min-32-znaki

# Wygeneruj z JWT_SECRET: https://supabase.com/docs/guides/self-hosting/docker#api-keys
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# Realtime (openssl rand -base64 64)
SECRET_KEY_BASE=zmien-na-64-znakowy-losowy-ciag

# --- Studio / Kong Dashboard ---
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=zmien-na-silne-haslo

# --- SMTP (Resend / dowolny) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxx
SMTP_ADMIN_EMAIL=admin@netszukacz.pl

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Sekrety aplikacji (Edge Functions) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
TRADEDOUBLER_TOKEN=
TRADEDOUBLER_WEBHOOK_SECRET=
TRADEDOUBLER_CLIENT_ID=
TRADEDOUBLER_CLIENT_SECRET=
TRADEDOUBLER_USERNAME=
TRADEDOUBLER_PASSWORD=
CRON_SECRET=
LOVABLE_API_KEY=
